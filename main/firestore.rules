rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Cualquiera que haya iniciado sesión con la app (aunque sea sesión
    // anónima) puede leer/escribir. Esto bloquea acceso directo desde
    // fuera de la app (bots, gente que encuentre tu projectId/apiKey),
    // pero NO distingue admin de vendedor — ambos roles hoy comparten el
    // mismo nivel de acceso a Firestore, porque esa distinción vive solo
    // en el PIN local (sessionStorage), no en Firebase Auth todavía.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
